<launch>

    <let name="joy_config_path" value="$(find-pkg-share piramide_bringup)/config/joy_truck.yaml"/>

    <!--
    variable that determies whether the published Twist messages should be stamped with the current time or not.
    -->
    <arg name="stamped" default="false"/>

    <node pkg="joy" exec="joy_node">
        <param from="$(var joy_config_path)" />
    </node>
    
    <node pkg="teleop_twist_joy" exec="teleop_node" name="teleop_node">
        <param from="$(var joy_config_path)" />
        <param name="publish_stamped_twist" value="$(var stamped)"/>
    </node>

</launch>