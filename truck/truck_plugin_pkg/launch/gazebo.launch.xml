<launch>
    <let name="control_gz_config_path" value="$(find-pkg-share truck_plugin_pkg)/config/ros_gz_bridge_gazebo.yaml" />
    <let name="sensors_gz_config_path" value="$(find-pkg-share truck_description)/config/ros_gz_bridge_gazebo.yaml" />
    <arg name="use_sim_time" default="true"/>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" name="control_bridge">
        <param name="config_file" value="$(var control_gz_config_path)" />
        <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>

    <node pkg="ros_gz_bridge" exec="parameter_bridge" name="sensors_bridge">
        <param name="config_file" value="$(var sensors_gz_config_path)" />
        <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>
</launch>